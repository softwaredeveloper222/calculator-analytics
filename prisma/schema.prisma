generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AnalyticsEvent {
  id                 String   @id @default(cuid())
  event              String
  calculatorId       String?
  sessionId          String
  deviceId           String
  appVersion         String?
  platform           String   @default("android")
  deviceManufacturer String?
  deviceModel        String?
  deviceBrand        String?
  osVersion          String?
  durationMs         Int?
  success            Boolean?
  metadata           String?
  createdAt          DateTime @default(now())

  @@index([calculatorId, createdAt])
  @@index([event, createdAt])
  @@index([deviceId])
  @@index([deviceId, createdAt])
  @@index([createdAt])
  @@index([platform, createdAt])
  @@index([deviceManufacturer, deviceModel])
}

model NotificationPage {
  id             String    @id @default(cuid())
  title          String
  subtitle       String?
  eventName      String?
  dateLabel      String?
  location       String?
  priceAttendee  String?
  priceExhibitor String?
  bullets        String    @default("[]")
  registerUrl    String?
  hotelsUrl      String?
  bodyHtml       String?
  heroImageUrl   String?
  images         String    @default("[]")
  version        Int       @default(1)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([publishedAt])
  @@index([updatedAt])
}
